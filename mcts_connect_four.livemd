## MCTS

```elixir
defmodule MCTS do
  defmodule Node do
    defstruct [
      :id, :args, :board, :parent_id, :action_taken,
      prior: 0,
      visit_count: 0,
      value_sum: 0,
      children_ids: []
    ]
  end

  defmodule Tree do
    use Agent

    def start_link, do: Agent.start_link(fn -> {%{}, 0} end)

    def stop(tree), do: Agent.stop(tree)

    # insere nó, retorna id atribuído
    def put_node(tree, node) do
      Agent.get_and_update(tree, fn {nodes, next_id} ->
        node = %{node | id: next_id}
        {next_id, {Map.put(nodes, next_id, node), next_id + 1}}
      end)
    end

    def get_node(tree, id) do
      Agent.get(tree, fn {nodes, _} -> Map.fetch!(nodes, id) end)
    end

    def update_node(tree, id, fun) do
      Agent.update(tree, fn {nodes, next_id} ->
        {Map.update!(nodes, id, fun), next_id}
      end)
    end

    def add_child(tree, parent_id, child_id) do
      update_node(tree, parent_id, fn node ->
        %{node | children_ids: node.children_ids ++ [child_id]}
      end)
    end
  end

  defstruct [:model, :args]

  def search(%{game: game} = alpha_zero, board) do
    {:ok, tree} = Tree.start_link()

    root_id =
      Tree.put_node(tree, 
        %Node{
          board:        board,
          parent_id:    nil,
          action_taken: nil,
          visit_count:  1
        })

    # inferência inicial + ruído Dirichlet
    {policy, _} = predict(board)

    valid_moves =
      board
      |> Game.get_valid_moves()
      |> Nx.to_flat_list()
    
    policy =
      policy
      |> Utils.add_dirichlet_noise(alpha_zero)
      |> Utils.mask_and_normalize(valid_moves)

    expand(tree, root_id, policy)

    # simulações
    Enum.each(1..game.num_mcts_searches, fn _ ->
      # selection
      node_id = select_leaf(tree, root_id)
      node    = Tree.get_node(tree, node_id)

      {value, is_terminal} =
        Game.get_value_and_terminated(game, node.board, node.action_taken)

      value = Game.get_opponent_value(value)

      value =
        if not is_terminal do
          {policy, value} = predict(node.board)
      
          valid_moves =
            board
            |> Game.get_valid_moves()
            |> Nx.to_flat_list()
          
          policy =
            policy
            |> add_dirichlet_noise(alpha_zero)
            |> Utils.mask_and_normalize(valid_moves)

          expand(tree, node_id, policy)

          value
          |> Nx.squeeze()
          |> Nx.to_number()
        else
          value
        end

      backpropagate(tree, node_id, value)
    end)

    # distribução final
    root     = Tree.get_node(tree, root_id)
    n        = game.action_size
    probs    = List.duplicate(0.0, n)

    probs =
      Enum.reduce(root.children_ids, probs, fn child_id, acc ->
        child = Tree.get_node(tree, child_id)
        List.replace_at(acc, child.action_taken, child.visit_count * 1.0)
      end)

    total = Enum.sum(probs)
    result = Enum.map(probs, fn v -> v / total end)

    Tree.stop(tree)
    result
  end

  # ── operações na árvore ───────────────────────────────────────────────

  defp expand(tree, node_id, policy) do
    node = Tree.get_node(tree, node_id)
    
    expands_child =
    Enum.map(Enum.with_index(policy), fn {prob, action} ->
      if prob > 0 do
        child_state =
          node.board
          |> Game.get_next_board(action, 1)
          |> Game.change_perspective(-1)

        child_id =
          Tree.put_node(tree, %Node{
            args:         node.args,
            board:        child_state,
            parent_id:    node_id,
            action_taken: action,
            prior:        prob
          })

        Tree.add_child(tree, node_id, child_id)
        Tree.get_node(tree, child_id)
      end
    end)
    
    {node, expands_child}
  end

  defp select_leaf(tree, node_id) do
    node = Tree.get_node(tree, node_id)

    if node.children_ids == [] do
      node_id
    else
      best_child_id =
        Enum.max_by(node.children_ids, fn child_id ->
          child = Tree.get_node(tree, child_id)
          get_ucb(node, child)
        end)

      select_leaf(tree, best_child_id)
    end
  end

  defp backpropagate(tree, node_id, value) do
    node = Tree.get_node(tree, node_id)

    Tree.update_node(tree, node_id, fn n ->
      %{n | value_sum: n.value_sum + value, visit_count: n.visit_count + 1}
    end)

    if node.parent_id != nil do
      backpropagate(tree, node.parent_id, Game.get_opponent_value(value))
    end
  end

  defp get_ucb(parent, child) do
    q_value =
      if child.visit_count == 0 do
        0
      else
        1 - (child.value_sum / child.visit_count + 1) / 2
      end

    q_value +
      2 * # parent.args.c
      (:math.sqrt(parent.visit_count) / (child.visit_count + 1)) *
      child.prior
  end

  defp predict(board) do
    inputs = Game.get_encoded_board(board)

    {policy, value} = ResNet.predict(inputs)
    
    policy =
      policy
      |> Axon.Activations.softmax(axis: 1)
      |> Nx.to_flat_list()

    {policy, value}
  end

  defp add_dirichlet_noise(policy, %{game: game} = _alpha_zero) do
    epsilon = game.dirichlet_epsilon
    noise   = Dirichlet.sample(List.duplicate(game.dirichlet_alpha, game.action_size))

    Enum.zip_with(policy, noise, fn p, n ->
      (1 - epsilon) * p + epsilon * n
    end)
  end

  defp mask_and_normalize(policy, valid_moves) do
    {policy, valid_moves}
    masked = Enum.zip_with(policy, valid_moves, fn p, v -> p * v end)
    total  = Enum.sum(masked)

    if total > 0 do
      Enum.map(masked, fn p -> p / total end)
    else
      n_valid = Enum.sum(valid_moves)
      Enum.map(valid_moves, fn v -> v / n_valid end)
    end
  end
end
```

## AlphaZero

```elixir
defmodule AlphaZero do
  use GenServer

  @fields [:model, :game, :args, :mcts, :memory]
  @type t :: %__MODULE__{
    model:  term(),
    game:   map(),
    args:   map(),
    mcts:   map(),
    memory: list()
  }

  defstruct @fields

  # ── API pública ────────────────────────────────────────────────────────

  def start_link(args) do
    GenServer.start_link(__MODULE__, args, name: __MODULE__)
  end

  def get_state do
    GenServer.call(__MODULE__, :get_state)
  end

  def new(args) do
    start_link(args)
    get_state()
  end

  def learn do
    alpha_zero = get_state()
    memory     = self_play(alpha_zero)
    IO.inspect(length(memory), label: "experiências coletadas")
    memory
  end

  # ── self_play ──────────────────────────────────────────────────────────

  def self_play(%{game: game} = alpha_zero) do
    board  = Nx.broadcast(Nx.tensor(0, type: :s32), {game.row_count, game.col_count})
    player = 1
    do_self_play(alpha_zero, board, player, _memory = [])
  end

  defp do_self_play(alpha_zero, board, player, memory) do
    %{game: game, args: args} = alpha_zero
  
    neutral_board     = Game.change_perspective(board, player)
    action_probs      = MCTS.search(alpha_zero, neutral_board)
    memory            = [{neutral_board, action_probs, player} | memory]
    temperature_probs = apply_temperature(action_probs, args.temperature)
  
    # garante que só escolhe colunas válidas
    valid_moves       = Game.get_valid_moves(board) |> Nx.to_flat_list()
    temperature_probs = mask_and_normalize(temperature_probs, valid_moves)
  
    action = sample_action(temperature_probs, game.action_size)
  
    new_board = Game.get_next_board(board, action, player)
  
    {value, is_terminal} = Game.get_value_and_terminated(new_board, action)
  
    if is_terminal do
      build_return_memory(memory, value, player, game)
    else
      do_self_play(alpha_zero, new_board, Game.get_opponent(player), memory)
    end
  end

  # ── helpers ────────────────────────────────────────────────────────────

  defp apply_temperature(action_probs, temperature) do
    probs =
      action_probs
      |> Enum.map(fn p -> :math.pow(p, 1.0 / temperature) end)

    total = Enum.sum(probs)
    Enum.map(probs, fn p -> p / total end)
  end

  defp sample_action(probs, action_size) do
    # equivalente ao np.random.choice(action_size, p=probs)
    r = :rand.uniform()

    probs
    |> Enum.with_index()
    |> Enum.reduce_while(0.0, fn {p, i}, acc ->
      acc = acc + p
      if r <= acc, do: {:halt, i}, else: {:cont, acc}
    end)
    |> then(fn
      i when is_integer(i) -> i
      _                    -> action_size - 1  # fallback rounding
    end)
  end

  defp build_return_memory(memory, value, current_player) do
    Enum.map(memory, fn {hist_board, hist_probs, hist_player} ->
      outcome =
        if hist_player == current_player,
          do:   value,
          else: Game.get_opponent_value(value)

      {
        Game.get_encoded_board(hist_board),  # input para a rede
        hist_probs,                          # target de policy
        outcome                              # target de value
      }
    end)
  end

  # ── GenServer callbacks ────────────────────────────────────────────────

  @impl true
  def init(args), do: {:ok, args}

  @impl true
  def handle_call(:get_state, _from, state), do: {:reply, state, state}

  @impl true
  def handle_cast({:update_memory, memory}, state) do
    {:noreply, %{state | memory: memory}}
  end

  @impl true
  def handle_cast({:update_params, params}, state) do
    {:noreply, %{state | model: params}}
  end
end
```

